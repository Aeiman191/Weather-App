generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Location {
  id        Int      @id @default(autoincrement())
  city      String
  region    String?
  country   String
  latitude  Float
  longitude Float
  createdAt DateTime @default(now())

  weatherRequests WeatherRequest[]

  @@unique([city, country])
}

model WeatherRequest {
  id          Int      @id @default(autoincrement())
  locationId  Int
  searchedAt  DateTime @default(now())

  // Current weather snapshot
  temperature Float
  humidity    Int
  windSpeed   Float
  condition   String

  // Optional extra weather information
  feelsLike   Float?
  uvIndex     Float?
  pressure    Float?
  visibility  Float?

  // Small JSON snapshot
  rawData Json?

  location Location @relation(fields: [locationId], references: [id])

  forecasts Forecast[]
}

model Forecast {
  id               Int      @id @default(autoincrement())
  weatherRequestId Int

  date DateTime

  averageTemp Float
  maxTemp     Float
  minTemp     Float

  humidity  Float
  windSpeed Float

  chanceOfRain Int?

  condition String
  icon      String?

weatherRequest WeatherRequest @relation(fields: [weatherRequestId], references: [id], onDelete: Cascade)
}