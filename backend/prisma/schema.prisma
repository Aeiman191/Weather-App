generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Location {
  id Int @id @default(autoincrement())

  city    String
  country String?

  latitude  Float
  longitude Float

  weatherRequests WeatherRequest[]

  createdAt DateTime @default(now())
}

model WeatherRequest {
  id Int @id @default(autoincrement())

  locationId Int
  location   Location @relation(fields: [locationId], references: [id])

  startDate DateTime
  endDate   DateTime

  temperature Float?
  humidity    Float?
  condition   String?
  windSpeed   Float?

  forecasts Forecast[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Forecast {
  id Int @id @default(autoincrement())

  weatherRequestId Int

  weatherRequest WeatherRequest @relation(fields: [weatherRequestId], references: [id], onDelete: Cascade)

  date DateTime

  temperature Float
  humidity    Float
  windSpeed   Float

  condition String

  icon String?
}
